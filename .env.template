# Copy this file to .env to override developer-controlled local bind ports
# and define the local paper-trading/iBeam runtime contract.
# The repo-level .env file stays ignored in git; this committed template defines
# the shared contract shape for local development and automated tests.
# When .env is absent, local startup and test helpers fall back to these values.
# Real IBKR usernames, passwords, account identifiers, session cookies, and tokens
# must never be committed here.

# Direct API startup (`dotnet run --project src/ATrade.Api/ATrade.Api.csproj`)
ATRADE_API_HTTP_PORT=5181

# Direct frontend startup (`cd frontend && npm run dev`)
ATRADE_FRONTEND_DIRECT_HTTP_PORT=3111

# AppHost-managed frontend startup (`./start run` or `dotnet run --project src/ATrade.AppHost/ATrade.AppHost.csproj`)
ATRADE_APPHOST_FRONTEND_HTTP_PORT=3000

# Aspire dashboard UI port for AppHost startup.
# 0 preserves Aspire's ephemeral loopback dashboard binding; set a non-zero
# local port in ignored .env when you need a stable dashboard URL.
ATRADE_ASPIRE_DASHBOARD_HTTP_PORT=0

# Paper-trading workspace and local iBeam placeholders.
# Broker integration remains disabled by default. To run iBeam locally, copy this
# file to .env, keep .env ignored, set ATRADE_BROKER_INTEGRATION_ENABLED=true,
# keep the gateway URL on HTTPS for the local iBeam Client Portal host port,
# and replace the fake IBKR_* placeholders with real paper-account values.
# ATRADE_IBKR_GATEWAY_PORT is the host bind port; AppHost maps it to the
# container's internal Client Portal port 5000.
ATRADE_BROKER_INTEGRATION_ENABLED=false
ATRADE_BROKER_ACCOUNT_MODE=Paper
ATRADE_IBKR_GATEWAY_URL=https://127.0.0.1:5000
ATRADE_IBKR_GATEWAY_PORT=5000
ATRADE_IBKR_GATEWAY_IMAGE=voyz/ibeam:latest
ATRADE_IBKR_GATEWAY_TIMEOUT_SECONDS=15
ATRADE_IBKR_USERNAME=IBKR_USERNAME
ATRADE_IBKR_PASSWORD=IBKR_PASSWORD
ATRADE_IBKR_PAPER_ACCOUNT_ID=IBKR_ACCOUNT_ID
ATRADE_FRONTEND_API_BASE_URL=http://127.0.0.1:5181
NEXT_PUBLIC_ATRADE_API_BASE_URL=http://127.0.0.1:5181

# Market-data cache settings. This non-secret value controls how fresh
# TimescaleDB market-data rows must be before API cache-aside reads may use them.
ATRADE_MARKET_DATA_CACHE_FRESHNESS_MINUTES=30

# Analysis engine placeholders. Analysis remains disabled by default; set
# ATRADE_ANALYSIS_ENGINE=Lean in ignored .env to invoke the official LEAN runtime.
ATRADE_ANALYSIS_ENGINE=none
ATRADE_LEAN_RUNTIME_MODE=cli
ATRADE_LEAN_CLI_COMMAND=lean
ATRADE_LEAN_DOCKER_COMMAND=docker
ATRADE_LEAN_DOCKER_IMAGE=quantconnect/lean:foundation
ATRADE_LEAN_WORKSPACE_ROOT=
ATRADE_LEAN_TIMEOUT_SECONDS=45
ATRADE_LEAN_KEEP_WORKSPACE=false

# iBeam container mapping verified from the upstream voyz/ibeam docs:
# - ATRADE_IBKR_GATEWAY_URL targets the HTTPS Client Portal API on the local port.
#   The gateway uses a self-signed development certificate; ATrade trusts it only
#   for loopback/local iBeam HTTPS traffic.
# - ATRADE_IBKR_USERNAME maps to container env IBEAM_ACCOUNT
# - ATRADE_IBKR_PASSWORD maps to container env IBEAM_PASSWORD
# - ATRADE_IBKR_PAPER_ACCOUNT_ID stays in ATrade only for paper account status
#   and is never passed to iBeam as a raw frontend/status value.

# Intentionally excluded from this contract:
# - Aspire dashboard OTLP and other AppHost internal host ports that stay on 127.0.0.1:0
# - Service/container target ports such as 5432 (Postgres), 6379 (Redis), and 4222 (NATS)
# - Real broker credentials or other secrets, which belong only in ignored .env
