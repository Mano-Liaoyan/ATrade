# Copy this file to .env to override developer-controlled local bind ports.
# The repo-level .env file stays ignored in git; this committed template defines
# the shared contract shape for local development.
# When .env is absent, local startup and test helpers fall back to these values.

# Direct API startup (`dotnet run --project src/ATrade.Api/ATrade.Api.csproj`)
ATRADE_API_HTTP_PORT=5181

# Direct frontend startup (`cd frontend && npm run dev`)
ATRADE_FRONTEND_DIRECT_HTTP_PORT=3111

# AppHost-managed frontend startup (`./start run` or `dotnet run --project src/ATrade.AppHost/ATrade.AppHost.csproj`)
ATRADE_APPHOST_FRONTEND_HTTP_PORT=3000

# Intentionally excluded from this contract:
# - AppHost internal host/dashboard ports that stay on 127.0.0.1:0
# - Service/container target ports such as 5432 (Postgres), 6379 (Redis), and 4222 (NATS)
