#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
command_name="${1:-}"

usage() {
  printf 'Usage: ./start run\n' >&2
}

case "$command_name" in
  run)
    shift
    exec "$repo_root/scripts/start.run.sh" "$@"
    ;;
  "")
    usage
    exit 1
    ;;
  *)
    printf 'Unsupported command: %s\n' "$command_name" >&2
    usage
    exit 1
    ;;
esac
